{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/investing-apps", "destination": "/investing", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/robots.txt",
      "has": [
        {
          "type": "host",
          "value": "^(?!www\\.)(?<partner>[a-z0-9-]+)\\.investingandretirement\\.com$"
        }
      ],
      "destination": "/partner-robots.txt"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "^(?!www\\.)(?<partner>[a-z0-9-]+)\\.investingandretirement\\.com$"
        }
      ],
      "destination": "https://eibmgedhnbssuzgtwlqh.supabase.co/functions/v1/redirect/_p/:partner/:path*"
    }
  ]
}
